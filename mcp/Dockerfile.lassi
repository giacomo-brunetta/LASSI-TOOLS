FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# System tooling required by the LASSI MCP server:
# - build-essential / clang / llvm / lld / libc++ / libclang-rt for sanitizer
#   and libFuzzer builds invoked by the verification tools
# - cmake / ninja / make / pkg-config for native project builds
# - hyperfine for run_benchmark
# - linux-tools-* provides `perf` (collect_perf_stats / profile_hotspots).
#   The binary is only useful when the host kernel exposes perf_event_open
#   to the container; the MCP tools degrade gracefully otherwise.
# - numactl, procps, util-linux for affinity/NUMA reporting and process info
# - python3.12 + venv + dev headers for the pip install layer
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      build-essential \
      ca-certificates \
      clang \
      cmake \
      coreutils \
      diffutils \
      findutils \
      git \
      hyperfine \
      libc++-dev \
      libc++abi-dev \
      libclang-rt-dev \
      linux-tools-common \
      linux-tools-generic \
      lld \
      llvm \
      make \
      ninja-build \
      numactl \
      pkg-config \
      procps \
      python3-dev \
      python3-pip \
      python3.12 \
      python3.12-venv \
      util-linux && \
    rm -rf /var/lib/apt/lists/*

# Python dependencies live in an isolated venv so the image stays
# compatible with Ubuntu 24.04's PEP 668 "externally-managed" Python.
RUN python3 -m venv /opt/lassi/.venv
ENV PATH="/opt/lassi/.venv/bin:${PATH}"

COPY requirements/requirements.txt /tmp/requirements.txt
RUN /opt/lassi/.venv/bin/pip install --upgrade pip && \
    /opt/lassi/.venv/bin/pip install -r /tmp/requirements.txt

# Bake the LASSI source last so dependency layers cache across edits.
WORKDIR /opt/lassi
COPY . /opt/lassi

# Stdio MCP server: the client (Claude / Codex / Roo) spawns this container
# with `docker run -i ...` and pipes JSON-RPC over stdin/stdout.
CMD ["/opt/lassi/.venv/bin/python", "/opt/lassi/mcp/LASSI_mcp.py"]
