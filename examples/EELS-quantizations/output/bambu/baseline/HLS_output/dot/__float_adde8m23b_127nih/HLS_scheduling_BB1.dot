digraph G {
//Scheduling solution
splines=ortho;
//Control Step: 0
CS0 [style=plaintext]
{rank=same; CS0  ;}
//Control Step: 1
CS1 [style=plaintext]
{rank=same; CS1  ;}
//Control Step: 2
CS2 [style=plaintext]
{rank=same; CS2  ;}
//Control Step: 3
CS3 [style=plaintext]
{rank=same; CS3  ;}
//Control Step: 4
CS4 [style=plaintext]
{rank=same; CS4  ;}
//Control Step: 5
CS5 [style=plaintext]
{rank=same; CS5 1  ;}
CS0 -> CS1;
CS1 -> CS2;
CS2 -> CS3;
CS3 -> CS4;
CS4 -> CS5;
CS5 -> 1 [style=invis weight=1000 color=dimgrey];
1[color=blue,shape=Msquare,label="EXIT - EXIT"];
}
